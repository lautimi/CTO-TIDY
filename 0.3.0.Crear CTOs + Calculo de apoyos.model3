            <Option name="static_value" value="CASE&#xd;&#xa;WHEN &quot;C_TOTAL&quot;&lt;3 THEN &quot;SECUENCIA&quot;&#xd;&#xa;WHEN &quot;C_TOTAL&quot;=3 AND &quot;SECUENCIA&quot;=1 THEN 3&#xd;&#xa;WHEN &quot;C_TOTAL&quot;=3 AND &quot;SECUENCIA&quot;=3 THEN 1&#xd;&#xa;&#xd;&#xa;WHEN &quot;C_TOTAL&quot;=4 AND &quot;SECUENCIA&quot;=2 THEN 3&#xd;&#xa;WHEN &quot;C_TOTAL&quot;=4 AND &quot;SECUENCIA&quot;=3 THEN 2&#xd;&#xa;&#xd;&#xa;WHEN &quot;C_TOTAL&quot;>4 AND &quot;C_TOTAL&quot;&lt;9 AND &quot;SECUENCIA&quot;=5 THEN 2&#xd;&#xa;WHEN &quot;C_TOTAL&quot;>4 AND &quot;C_TOTAL&quot;&lt;9 AND &quot;SECUENCIA&quot;=2 THEN 5&#xd;&#xa;&#xd;&#xa;WHEN &quot;C_TOTAL&quot;>6 AND &quot;C_TOTAL&quot;&lt;13 AND &quot;SECUENCIA&quot;=7 THEN 4&#xd;&#xa;WHEN &quot;C_TOTAL&quot;>6 AND &quot;C_TOTAL&quot;&lt;13 AND &quot;SECUENCIA&quot;=4 THEN 7&#xd;&#xa;&#xd;&#xa;WHEN &quot;C_TOTAL&quot;>8 AND &quot;C_TOTAL&quot;&lt;14 AND &quot;SECUENCIA&quot;=9 THEN 2&#xd;&#xa;WHEN &quot;C_TOTAL&quot;>8 AND &quot;C_TOTAL&quot;&lt;14 AND &quot;SECUENCIA&quot;=2 THEN 9&#xd;&#xa;&#xd;&#xa;WHEN &quot;C_TOTAL&quot;>10 AND &quot;C_TOTAL&quot;&lt;14 AND &quot;SECUENCIA&quot;=11 THEN 6&#xd;&#xa;WHEN &quot;C_TOTAL&quot;>10 AND &quot;C_TOTAL&quot;&lt;14 AND &quot;SECUENCIA&quot;=6 THEN 11&#xd;&#xa;&#xd;&#xa;WHEN &quot;C_TOTAL&quot;=13 AND &quot;SECUENCIA&quot;=13 THEN 4&#xd;&#xa;WHEN &quot;C_TOTAL&quot;=13 AND &quot;SECUENCIA&quot;=4 THEN 13&#xd;&#xa;&#xd;&#xa;ELSE &quot;SECUENCIA&quot;&#xd;&#xa;END" type="QString"/>
          </Option>
        </Option>
        <Option name="INPUT" type="List">
          <Option type="Map">
            <Option name="child_id" value="native:refactorfields_8" type="QString"/>
            <Option name="output_name" value="OUTPUT" type="QString"/>
